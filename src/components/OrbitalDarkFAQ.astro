---
import { ChevronDown } from "@lucide/astro";

const faqs = [
  { question: "What DAWs does Orbital support?", answer: "Orbital works with Ableton Live, Logic Pro, Studio One, FL Studio, and GarageBand — any DAW that supports VST3 or AU. 64-bit only. macOS 11+ or Windows 10+." },
  { question: "Can I use Orbital commercially?", answer: "Yes. Your license covers both personal and commercial use. Any music you create with Orbital is 100% yours to release, sell, or license — completely royalty-free." },
  { question: "Do I get free updates?", answer: "Yes — lifetime updates included. We regularly release new presets, features, and performance improvements at no extra cost." },
  { question: "What are the system requirements?", answer: "Windows 10+ or macOS 11+, a 64-bit DAW, at least 4GB RAM (8GB recommended), and 500MB of free disk space for the full preset library." },
  { question: "How are the presets organized?", answer: "175 presets across six collections: Analog Keys, Cinematic Pads, Melodic Leads, Plucks & Tones, Analog Bass, and Tonal Synths — all sampled from real hardware like the Juno-106, Prophet-5, Minimoog, and Jupiter-8." },
  { question: "How will I receive the plugin after purchase?", answer: "You'll receive the installer and license key by email right after checkout. Download, install, enter your key, and you're ready to produce." },
  { question: "What is your refund policy?", answer: "15-day money-back guarantee on all purchases. If Orbital isn't for you, email info.creativaudio@gmail.com within 15 days and we'll issue a full refund — no questions asked." },
  { question: "How do I get support?", answer: "Email info.creativaudio@gmail.com and our team will respond within 24 hours on weekdays." },
];
---

<section id="faq" class="relative bg-[#08080A] flex flex-col items-center gap-12 py-20 md:py-[120px] px-6 md:px-16 lg:px-[120px] overflow-hidden">
  <div class="flex flex-col items-center gap-4 text-center" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">FAQ</span>
    <h2 class="font-heading text-3xl md:text-[52px] font-bold text-white tracking-[-1.5px] leading-[1.05]">Frequently Asked Questions</h2>
    <p class="text-lg text-white/60 leading-relaxed max-w-[600px]">Everything you need to know about Orbital.</p>
  </div>

  <div class="w-full max-w-[800px] rounded-2xl bg-white/[0.03] border border-white/10 px-8 md:px-10 py-2 backdrop-blur-sm" data-animate="scale-in">
    {faqs.map((faq, index) => (
      <details class:list={["group", index < faqs.length - 1 ? "border-b border-white/10" : ""]}>
        <summary class="flex justify-between items-center py-6 cursor-pointer text-white font-medium text-base hover:text-accent transition-colors">
          {faq.question}
          <ChevronDown size={20} class="text-white/40 transition-transform duration-200 group-open:rotate-180 group-open:text-accent shrink-0 ml-4" />
        </summary>
        <p class="pb-6 text-[15px] text-white/60 leading-relaxed">{faq.answer}</p>
      </details>
    ))}
  </div>
</section>
