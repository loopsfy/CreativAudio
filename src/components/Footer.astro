---
const columns = [
  { title: "Product", links: ["Features", "Presets", "Pricing", "Changelog"] },
  { title: "Support", links: ["Documentation", "Tutorials", "Contact", "FAQ"] },
  { title: "Company", links: ["About", "Blog", "Careers", "Press Kit"] },
];
---

<footer class="flex flex-col gap-12 bg-surface-footer py-12 md:py-16 px-6 md:px-16 lg:px-[120px]">
  <!-- Footer Main -->
  <div class="flex flex-col lg:flex-row lg:justify-between gap-12">
    <!-- Brand Column -->
    <div class="lg:max-w-[300px]">
      <img src="/creativ-audio-logo.png" alt="CreativAudio" class="h-8 w-auto" />
      <p class="text-sm text-text-body mt-4 leading-relaxed">Next-generation audio synthesis tools for modern producers.</p>
    </div>

    <!-- Nav Columns -->
    <div class="flex flex-col sm:flex-row gap-12 sm:gap-16 lg:gap-20">
      {columns.map((col) => (
        <div>
          <h4 class="text-sm font-semibold text-text-primary mb-4">{col.title}</h4>
          <ul class="flex flex-col gap-2.5">
            {col.links.map((link) => (
              <li>
                <a href="#" class="text-sm text-text-body hover:text-text-primary transition-colors">{link}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Footer Divider -->
  <div class="w-full h-px bg-border"></div>

  <!-- Footer Bottom -->
  <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-xs text-text-lighter">&copy; 2026 CreativAudio. All rights reserved.</p>
    <div class="flex gap-6">
      <a href="#" class="text-xs text-text-lighter hover:text-text-primary transition-colors">Privacy Policy</a>
      <a href="#" class="text-xs text-text-lighter hover:text-text-primary transition-colors">Terms of Service</a>
      <a href="#" class="text-xs text-text-lighter hover:text-text-primary transition-colors">Refund Policy</a>
    </div>
  </div>
</footer>
