---
import { Check } from "@lucide/astro";
import AddToCartButton from "./AddToCartButton";

const features = [
  "175 Ready-to-Use Presets",
  "5 Built-in Effects (Reverb, Delay, Filter, Vibrato, Stutter)",
  "4 Color Skins",
  "Drag & Drop Your Own Samples",
  "Free Lifetime Updates",
];
---

<section id="pricing" class="pricing-grid relative flex flex-col items-center gap-6 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px] bg-[#0D0D0F]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px]">PRICING</span>
    <h2 class="font-heading text-4xl md:text-[48px] font-bold text-white tracking-[-1px] text-center">The Only Plugin You'll Need.</h2>
  </div>

  <!-- Launch Offer Countdown -->
  <div class="flex flex-col items-center gap-3">
    <span class="text-[11px] font-semibold text-accent tracking-[2px]">LAUNCH OFFER ENDS IN</span>
    <div class="flex gap-1.5 items-center" id="countdown-timer">
      <div class="rounded-lg bg-white/10 px-3 py-2.5 flex flex-col items-center gap-0.5 min-w-[52px]">
        <span class="font-mono text-2xl font-bold text-white" id="timer-hrs">00</span>
        <span class="text-[10px] text-white/40">HRS</span>
      </div>
      <span class="font-mono text-xl text-white/30">:</span>
      <div class="rounded-lg bg-white/10 px-3 py-2.5 flex flex-col items-center gap-0.5 min-w-[52px]">
        <span class="font-mono text-2xl font-bold text-white" id="timer-min">00</span>
        <span class="text-[10px] text-white/40">MIN</span>
      </div>
      <span class="font-mono text-xl text-white/30">:</span>
      <div class="rounded-lg bg-white/10 px-3 py-2.5 flex flex-col items-center gap-0.5 min-w-[52px]">
        <span class="font-mono text-2xl font-bold text-white" id="timer-sec">00</span>
        <span class="text-[10px] text-white/40">SEC</span>
      </div>
    </div>
  </div>

  <script>
    function updateCountdown() {
      const now = new Date();
      const endOfDay = new Date(now);
      endOfDay.setHours(23, 59, 59, 999);
      const diff = endOfDay.getTime() - now.getTime();

      const hrs = Math.floor(diff / (1000 * 60 * 60));
      const min = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const sec = Math.floor((diff % (1000 * 60)) / 1000);

      document.getElementById("timer-hrs")!.textContent = String(hrs).padStart(2, "0");
      document.getElementById("timer-min")!.textContent = String(min).padStart(2, "0");
      document.getElementById("timer-sec")!.textContent = String(sec).padStart(2, "0");
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  </script>

  <!-- Pricing Card -->
  <div class="rounded-xl bg-[#161618] border border-white/10 p-7 flex flex-col gap-3 w-full max-w-[360px] items-center" data-animate="scale-in">
    <!-- Product Image -->
    <img src="/orbital-plugin.png" alt="Orbital Plugin" class="w-full rounded-lg -mt-8 -mb-6" />

    <!-- Plan Name -->
    <span class="text-lg font-heading font-bold text-white tracking-[1px]">GET ORBITAL</span>

    <!-- Price Group -->
    <div class="flex items-baseline gap-3 -mt-1">
      <span class="text-4xl font-heading font-bold text-white">$49</span>
      <span class="text-base text-white/30 line-through">$119</span>
    </div>
    <span class="text-sm text-white/50 -mt-2">one-time purchase</span>

    <!-- Feature List -->
    <div class="flex flex-col gap-3 self-stretch">
      {features.map((feature) => (
        <div class="flex items-center gap-3">
          <Check size={18} class="text-accent shrink-0" />
          <span class="text-[15px] text-white/70">{feature}</span>
        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <AddToCartButton client:visible />
  </div>

  <!-- Platform Support -->
  <span class="text-sm text-white/50" data-animate="fade-up">VST3 / AU Support (Windows & macOS)</span>
</section>

<style>
  .pricing-grid::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 200px 200px;
    pointer-events: none;
  }
  .pricing-grid::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .pricing-grid > * {
    position: relative;
    z-index: 1;
  }
</style>
