---
import { Waves, Sparkles, Sliders, Shuffle, Monitor, Zap } from "@lucide/astro";

const features = [
  { icon: Waves, title: "3 Oscillator Engines", description: "Three independent oscillator engines with wavetable, subtractive, and FM synthesis modes for limitless sound design." },
  { icon: Sparkles, title: "Spectral Effects Suite", description: "Built-in spectral processing with reverb, delay, chorus, and our signature Orbital shimmer effect." },
  { icon: Sliders, title: "Intelligent Modulation", description: "Smart modulation routing that learns your style and suggests creative parameter connections." },
  { icon: Shuffle, title: "Preset Morphing", description: "Seamlessly blend between any two presets in real-time for evolving, dynamic soundscapes." },
  { icon: Monitor, title: "Visual Feedback Engine", description: "Real-time waveform visualization and spectrum analysis for precise sound design feedback." },
  { icon: Zap, title: "Built for Performance", description: "Optimized DSP engine with near-zero latency, designed to handle complex patches without dropouts." },
];
---

<section id="features" class="flex flex-col items-center gap-12 md:gap-16 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4 text-center" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">FEATURES</span>
    <h2 class="font-heading text-3xl md:text-[48px] font-bold text-text-primary tracking-tight leading-tight">Designed for the Future of Sound</h2>
    <p class="text-base md:text-lg text-text-body leading-relaxed text-center max-w-[600px]">
      Orbital combines cutting-edge synthesis technology with an intuitive interface, giving you unprecedented control over your sound.
    </p>
  </div>

  <!-- Feature Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-[1200px]" data-animate="stagger">
    {features.map(({ icon: Icon, title, description }) => (
      <div class="rounded-xl bg-[#0D0D0F] border border-white/10 p-8 flex flex-col gap-5 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_-20%,_rgba(255,92,0,0.08)_0%,_transparent_60%)]"></div>
        <div class="relative">
          <Icon size={24} class="text-accent" />
        </div>
        <h3 class="text-lg font-semibold text-white relative">{title}</h3>
        <p class="text-[15px] text-white/50 leading-relaxed relative">{description}</p>
      </div>
    ))}
  </div>
</section>
