---
import { Play, ArrowRight } from "@lucide/astro";

const presets = [
  { name: "Cosmic Drift", category: "Ambient Pad", genre: "Ambient" },
  { name: "Neural Bass", category: "Bass", genre: "Dubstep" },
  { name: "Quantum Pad", category: "Pad", genre: "Cinematic" },
  { name: "Digital Rain", category: "Arpeggio", genre: "Electronica" },
  { name: "Void Lead", category: "Lead", genre: "Synthwave" },
];
---

<section id="presets" class="flex flex-col items-center gap-12 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px] bg-surface">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4 text-center" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">SOUND LIBRARY</span>
    <h2 class="font-heading text-3xl md:text-[48px] font-bold text-text-primary tracking-tight leading-tight">Explore the Sound</h2>
    <p class="text-base md:text-lg text-text-body leading-relaxed text-center max-w-[600px]">
      Browse through 500+ professionally designed presets spanning every genre and style.
    </p>
  </div>

  <!-- Preset List -->
  <div class="flex flex-col gap-0.5 w-full max-w-[1200px]" data-animate="stagger">
    {presets.map(({ name, category, genre }, index) => (
      <div class:list={[
        "flex flex-col sm:flex-row sm:items-center sm:justify-between rounded-lg p-5 sm:px-6 gap-3 sm:gap-0",
        index % 2 === 0 ? "bg-card" : "bg-[#F5F5F7]"
      ]}>
        <div class="flex items-center gap-3">
          <span class="text-[15px] font-medium text-text-primary">{name}</span>
          <span class="text-[13px] text-text-body">{category}</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-xs font-medium text-text-secondary bg-white rounded-full px-3 py-1">{genre}</span>
          <Play size={18} class="text-text-secondary cursor-pointer" />
        </div>
      </div>
    ))}
  </div>

  <!-- CTA Button -->
  <a href="#pricing" class="mt-4 inline-flex items-center gap-2 rounded-md border border-border-medium px-8 py-3.5 text-[13px] font-medium text-text-secondary tracking-[0.5px] hover:bg-card transition-colors">
    GET ORBITAL NOW
    <ArrowRight size={16} />
  </a>
</section>
