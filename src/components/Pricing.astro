---
import { Check, ArrowRight } from "@lucide/astro";

const features = [
  "3 Oscillator Engines",
  "500+ Factory Presets",
  "Spectral Effects Suite",
  "Free Lifetime Updates",
  "Preset Morphing Engine",
  "VST3 / AU / AAX Support",
];
---

<section class="flex flex-col items-center gap-12 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px] bg-[radial-gradient(ellipse_at_center,_#FFF0E6_0%,_#FFFFFF_70%)]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4">
    <span class="text-xs font-semibold text-accent tracking-[2px]">PRICING</span>
    <h2 class="font-heading text-4xl md:text-[48px] font-normal text-text-primary tracking-[-1px] text-center">One Plugin. One Price. No Subscriptions.</h2>
  </div>

  <!-- Launch Offer Countdown -->
  <div class="flex flex-col items-center gap-3">
    <span class="text-[11px] font-semibold text-accent tracking-[2px]">LAUNCH OFFER ENDS IN</span>
    <div class="flex gap-3 items-center">
      <div class="rounded-lg bg-timer-bg px-4 py-3 flex flex-col items-center gap-0.5 min-w-[60px]">
        <span class="font-mono text-2xl font-bold text-white">12</span>
        <span class="text-[10px] text-text-lighter">HRS</span>
      </div>
      <span class="font-mono text-xl text-border-medium">:</span>
      <div class="rounded-lg bg-timer-bg px-4 py-3 flex flex-col items-center gap-0.5 min-w-[60px]">
        <span class="font-mono text-2xl font-bold text-white">34</span>
        <span class="text-[10px] text-text-lighter">MIN</span>
      </div>
      <span class="font-mono text-xl text-border-medium">:</span>
      <div class="rounded-lg bg-timer-bg px-4 py-3 flex flex-col items-center gap-0.5 min-w-[60px]">
        <span class="font-mono text-2xl font-bold text-white">56</span>
        <span class="text-[10px] text-text-lighter">SEC</span>
      </div>
    </div>
  </div>

  <!-- Pricing Card -->
  <div class="rounded-xl bg-card border border-border p-10 flex flex-col gap-8 w-full max-w-[380px] items-center">
    <!-- Plan Name -->
    <span class="text-sm font-semibold text-accent tracking-[2px]">ORBITAL PRO</span>

    <!-- Price Group -->
    <div class="flex flex-col items-center gap-1">
      <span class="text-lg text-text-light line-through">$299</span>
      <span class="text-5xl font-heading font-bold text-text-primary">$149</span>
      <span class="text-sm text-text-body">one-time purchase</span>
    </div>

    <!-- Feature List -->
    <div class="flex flex-col gap-3 self-stretch">
      {features.map((feature) => (
        <div class="flex items-center gap-3">
          <Check size={18} class="text-accent shrink-0" />
          <span class="text-[15px] text-text-body">{feature}</span>
        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <a href="#" class="w-full inline-flex items-center justify-center gap-2 rounded-md bg-gradient-to-r from-accent to-accent-end px-8 py-4 text-[15px] font-semibold text-white tracking-[1px]">
      GET ORBITAL
      <ArrowRight size={18} />
    </a>
  </div>
</section>
