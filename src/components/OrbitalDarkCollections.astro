---
import { Play, Pause, ArrowRight } from "@lucide/astro";

const collections = [
  {
    id: "keys",
    name: "Analog Keys",
    count: "42 Presets",
    tagline: "Expressive Keys Inspired by Classic Hardware",
    copy: "Warm, characterful keys sampled directly from the Juno-106 and Prophet-5. From dusty lo-fi tones to clean, cinematic pianos — ready to sit in any mix without extra processing.",
    file: "/audio/nostalgia.mp3",
    tracks: ["Nostalgia", "Alert", "Velvet Keys", "Dusty Rhodes"],
    hue: "from-[#ff6a3a]/25 to-[#ff3c00]/5",
  },
  {
    id: "pads",
    name: "Cinematic Pads",
    count: "36 Presets",
    tagline: "Lush Textures That Fill the Room",
    copy: "Ambient pads recorded through analog signal chains — perfect for setting mood, layering under vocals, or building cinematic space. Every pad breathes with real hardware movement.",
    file: "/audio/astral.mp3",
    tracks: ["Astral", "Drift", "Aurora", "Glacier"],
    hue: "from-[#7a5cff]/25 to-[#3a1cff]/5",
  },
  {
    id: "leads",
    name: "Melodic Leads",
    count: "28 Presets",
    tagline: "Leads That Cut Through Any Mix",
    copy: "Expressive lead sounds engineered to sit in the pocket. From Minimoog-style mono leads to Jupiter-8 polys — each one crafted for instant melodic inspiration.",
    file: "/audio/jade.mp3",
    tracks: ["Jade", "Solar", "Ember", "Pulse"],
    hue: "from-[#00c2ff]/25 to-[#005cff]/5",
  },
  {
    id: "plucks",
    name: "Plucks & Tones",
    count: "30 Presets",
    tagline: "Tonal Textures for Melodic Ideas",
    copy: "Articulate plucks and harmonic tones that give melodies clarity and character. Perfect for building strong hooks, arps, and rhythmic patterns with immediate musicality.",
    file: "/audio/glow.mp3",
    tracks: ["Glow", "Crystal", "Facet", "Ripple"],
    hue: "from-[#00ffa8]/25 to-[#00a86b]/5",
  },
  {
    id: "bass",
    name: "Analog Bass",
    count: "22 Presets",
    tagline: "Fat, Warm, Hardware-Driven Low End",
    copy: "Bass sounds recorded from legendary mono synths. From deep sub-foundations to driven mid-bass growls — every preset delivers real analog weight and saturation.",
    file: "/audio/boom.mp3",
    tracks: ["Boom", "Sub", "Growl", "Thunder"],
    hue: "from-[#ff00c8]/25 to-[#8800ff]/5",
  },
  {
    id: "synths",
    name: "Tonal Synths",
    count: "17 Presets",
    tagline: "Foundational Sounds for Any Genre",
    copy: "A reliable, all-purpose library that makes building strong melodic ideas fast, intuitive, and consistently high quality. The building blocks of every session.",
    file: "/audio/jade.mp3",
    tracks: ["Engine", "Orbit", "Nova", "Relay"],
    hue: "from-[#ffc800]/25 to-[#ff6a00]/5",
  },
];
---

<section id="collections" class="relative bg-[#050507] py-20 md:py-[120px] px-6 md:px-16 lg:px-[120px] overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[radial-gradient(circle_at_center,rgba(255,92,0,0.08),transparent_70%)] blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="flex flex-col items-center gap-4 text-center mb-16" data-animate="fade-up">
      <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">Preset Collections</span>
      <h2 class="font-heading text-3xl md:text-[52px] font-bold text-white tracking-[-1.5px] leading-[1.05]">
        Six Collections. <span class="bg-gradient-to-r from-accent to-accent-end bg-clip-text text-transparent">One Plugin.</span>
      </h2>
      <p class="text-base md:text-lg text-white/60 leading-relaxed max-w-[640px]">
        175 presets crafted from real analog synths, organized into six collections designed to cover every production need — from melodic foundations to cinematic textures.
      </p>
    </div>

    <!-- Collection Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6" data-animate="stagger">
      {collections.map((col) => (
        <article
          data-collection
          data-file={col.file}
          class="group relative rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.01] overflow-hidden hover:border-white/20 transition-all"
        >
          <!-- Hue overlay -->
          <div class={`absolute inset-0 bg-gradient-to-br ${col.hue} opacity-60 group-hover:opacity-100 transition-opacity pointer-events-none`}></div>

          <div class="relative p-7 md:p-8 flex flex-col gap-5 h-full">
            <!-- Header row -->
            <div class="flex items-start justify-between gap-4">
              <div class="flex flex-col gap-1">
                <span class="font-mono text-[11px] font-medium text-white/40 tracking-[1.5px] uppercase">{col.count}</span>
                <h3 class="font-heading text-2xl md:text-[28px] font-bold text-white tracking-tight leading-tight">{col.name}</h3>
              </div>
              <button
                class="collection-play shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-white/10 border border-white/15 text-white hover:bg-accent hover:border-accent transition-colors cursor-pointer"
                aria-label={`Preview ${col.name}`}
              >
                <Play size={18} class="play-icon ml-0.5" />
                <Pause size={18} class="pause-icon hidden" />
              </button>
            </div>

            <!-- Tagline -->
            <p class="text-base font-medium text-white/90 leading-snug">{col.tagline}</p>

            <!-- Copy -->
            <p class="text-sm text-white/55 leading-relaxed flex-1">{col.copy}</p>

            <!-- Tracks -->
            <div class="flex flex-wrap gap-2 pt-2 border-t border-white/5">
              {col.tracks.map((t) => (
                <span class="text-[11px] font-mono text-white/50 bg-white/5 rounded-full px-3 py-1">{t}</span>
              ))}
            </div>

            <!-- Progress bar -->
            <div class="collection-progress hidden absolute bottom-0 left-0 right-0 h-[2px] bg-white/5 overflow-hidden">
              <div class="collection-progress-bar h-full bg-accent w-0"></div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex justify-center mt-14" data-animate="fade-up">
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 rounded-md bg-gradient-to-r from-accent to-accent-end px-10 py-4 text-[15px] font-semibold text-white tracking-[1px] hover:opacity-95 transition-opacity shadow-[0_0_48px_-8px_rgba(255,92,0,0.7)]"
      >
        UNLOCK ALL 175 PRESETS
        <ArrowRight size={18} />
      </a>
    </div>
  </div>
</section>

<style>
  [data-collection].playing .play-icon { display: none; }
  [data-collection].playing .pause-icon { display: block; }
  [data-collection].playing .collection-progress { display: block; }
  [data-collection].playing .collection-play {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
</style>

<script>
  let currentAudio: HTMLAudioElement | null = null;
  let currentCol: HTMLElement | null = null;

  document.querySelectorAll('[data-collection]').forEach((el) => {
    const card = el as HTMLElement;
    const btn = card.querySelector('.collection-play') as HTMLButtonElement;
    const file = card.dataset.file!;
    const progressBar = card.querySelector('.collection-progress-bar') as HTMLElement;

    btn.addEventListener('click', () => {
      if (currentCol === card && currentAudio && !currentAudio.paused) {
        currentAudio.pause();
        card.classList.remove('playing');
        return;
      }

      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentCol?.classList.remove('playing');
      }

      currentAudio = new Audio(file);
      currentCol = card;
      card.classList.add('playing');

      currentAudio.addEventListener('timeupdate', () => {
        if (currentAudio && currentAudio.duration) {
          progressBar.style.width = `${(currentAudio.currentTime / currentAudio.duration) * 100}%`;
        }
      });

      currentAudio.addEventListener('ended', () => {
        card.classList.remove('playing');
        progressBar.style.width = '0%';
        currentAudio = null;
        currentCol = null;
      });

      currentAudio.play();
    });
  });
</script>
