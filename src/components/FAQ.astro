---
import { ChevronDown } from "@lucide/astro";

const faqs = [
  { question: "What DAWs does Orbital support?", answer: "Orbital supports all major DAWs including Ableton Live, FL Studio, Logic Pro, Pro Tools, Cubase, Studio One, Reaper, and Bitwig. Available as VST3, AU, and AAX plugin formats for both Windows and macOS." },
  { question: "Do I get free updates?", answer: "Yes! Your purchase includes free lifetime updates. We regularly release new presets, features, and performance improvements at no additional cost." },
  { question: "Can I use Orbital commercially?", answer: "Absolutely. Your Orbital license covers both personal and commercial use. Any music you create with Orbital is 100% yours to release, sell, or license." },
  { question: "What are the system requirements?", answer: "Orbital requires Windows 10+ or macOS 11+, a 64-bit DAW, at least 4GB RAM (8GB recommended), and 500MB of free disk space for the full preset library." },
  { question: "How does the preset library work?", answer: "Orbital comes with 500+ professionally designed presets organized by category and genre. You can browse, preview, and morph between presets in real-time. Custom presets can be saved and shared." },
];
---

<section class="flex flex-col items-center gap-12 bg-surface py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4 text-center">
    <span class="text-xs font-semibold text-accent tracking-[2px]">FAQ</span>
    <h2 class="font-heading text-3xl md:text-[48px] font-normal text-text-primary tracking-[-1px] leading-tight">Frequently Asked Questions</h2>
    <p class="text-lg text-text-body leading-relaxed max-w-[600px]">Everything you need to know about Orbital.</p>
  </div>

  <!-- FAQ List -->
  <div class="w-full max-w-[800px]">
    {faqs.map((faq, index) => (
      <details class:list={["group", index < faqs.length - 1 ? "border-b border-border" : ""]}>
        <summary class="flex justify-between items-center py-6 cursor-pointer text-text-primary font-medium text-base">
          {faq.question}
          <ChevronDown size={20} class="text-text-light transition-transform duration-200 group-open:rotate-180 shrink-0 ml-4" />
        </summary>
        <p class="pb-6 text-[15px] text-text-body leading-relaxed">{faq.answer}</p>
      </details>
    ))}
  </div>
</section>
