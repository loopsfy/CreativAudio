---
import { Star, BadgeCheck } from "@lucide/astro";

const stats = [
  { value: "2,100+", label: "Producers Trust Us" },
  { value: "175", label: "Analog Presets" },
  { value: "4.9/5", label: "Average Rating" },
  { value: "15-Day", label: "Money-Back" },
];

const testimonials = [
  { quote: "the pads on this are beautiful. they have this warm analog feel that just sits in the mix without touching anything. first thing I load every session now", author: "Alex Rivera", img: "https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?w=80&h=80&fit=crop&crop=face" },
  { quote: "The keys are so clean and expressive. I use them on literally every beat, they just have that warmth that makes everything sound more professional", author: "Sarah Chen", img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" },
  { quote: "The leads cut through the mix so well without any extra EQ. Haven't found another plugin that nails melodies like this one does", author: "Marcus Johnson", img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" },
  { quote: "Those pads are something else. they fill up a track so nicely without being too much. perfect for setting the mood on any type of beat", author: "Lena Krüger", img: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=80&h=80&fit=crop&crop=face" },
  { quote: "Super intuitive interface, figured everything out in like 2 minutes. And being able to switch skins is a nice touch. Best looking plugin I own honestly", author: "Davi Santos", img: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=80&h=80&fit=crop&crop=face" },
  { quote: "the keys have this character that I can't get from any other plugin. every time I open it I end up making a whole new beat from scratch", author: "Jordan Park", img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=80&h=80&fit=crop&crop=face" },
  { quote: "every lead sound just works. no fighting with the mix, no clashing. they sit exactly where they need to. saves me so much time", author: "Nia Okafor", img: "https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=80&h=80&fit=crop&crop=face" },
  { quote: "The pads give my tracks this cinematic feel that I could never get before. my vocalist stopped the session to ask what sound that was", author: "David Lin", img: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop&crop=face" },
  { quote: "The keys sound warm and natural, not digital at all. Perfect for R&B and soul. Honestly can't believe the quality for this price", author: "Mika Tanaka", img: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=80&h=80&fit=crop&crop=face" },
  { quote: "I bought it for the leads but the pads are what I use the most now. they add so much depth to everything. this plugin is a permanent part of my setup", author: "Carlos Vega", img: "https://images.unsplash.com/photo-1463453091185-61582044d556?w=80&h=80&fit=crop&crop=face" },
];
---

<section id="reviews" class="relative bg-[#050507] flex flex-col items-center gap-12 md:gap-16 py-20 md:py-[120px] px-6 md:px-16 lg:px-[120px] overflow-hidden">
  <!-- Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-[radial-gradient(ellipse_at_center,rgba(255,92,0,0.12),transparent_70%)] blur-3xl pointer-events-none"></div>

  <div class="relative z-10 flex flex-col items-center gap-4 text-center" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">Trusted By Producers</span>
    <h2 class="font-heading text-4xl md:text-[52px] font-bold text-white tracking-[-1.5px] text-center leading-[1.05]">What Producers Say</h2>
  </div>

  <!-- Stats Row -->
  <div class="relative z-10 grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 w-full max-w-[900px]" data-animate="stagger">
    {stats.map((stat) => (
      <div class="flex flex-col items-center gap-1.5 rounded-xl bg-gradient-to-b from-white/[0.06] to-white/[0.01] border border-white/10 py-6 px-5 backdrop-blur-sm">
        <span class="text-2xl md:text-3xl font-heading font-bold text-white">{stat.value}</span>
        <span class="text-xs md:text-sm text-white/60 tracking-wide text-center">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Testimonials Desktop -->
  <div class="hidden md:block w-full max-w-full overflow-hidden relative" data-animate="fade-in">
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-r from-[#050507] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-l from-[#050507] to-transparent z-10 pointer-events-none"></div>

    <div class="flex gap-6 dark-carousel-track">
      {[...testimonials, ...testimonials].map((t) => (
        <div class="min-w-[340px] max-w-[340px] rounded-xl bg-white/[0.03] border border-white/10 p-8 flex flex-col gap-5 shrink-0 backdrop-blur-sm">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <Star size={16} class="text-accent fill-accent" />
            ))}
          </div>
          <p class="text-[15px] text-white/75 leading-relaxed flex-1">"{t.quote}"</p>
          <div class="flex items-center gap-3">
            <img src={t.img} alt={t.author} width="40" height="40" class="w-10 h-10 rounded-full object-cover" loading="lazy" />
            <div class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold text-white">{t.author}</span>
              <span class="text-xs text-accent flex items-center gap-1">
                <BadgeCheck size={14} class="text-accent" />
                Verified Buyer
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Testimonials Mobile -->
  <div class="md:hidden w-full max-w-full flex flex-col gap-3 relative" data-animate="fade-in">
    <div class="absolute left-0 top-0 bottom-0 w-12 bg-gradient-to-r from-[#050507] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-[#050507] to-transparent z-10 pointer-events-none"></div>

    {[
      { items: testimonials.slice(0, Math.ceil(testimonials.length / 2)), dir: "left" },
      { items: testimonials.slice(Math.ceil(testimonials.length / 2)), dir: "right" },
    ].map((row) => (
      <div class="overflow-hidden w-full">
        <div class={`flex gap-3 ${row.dir === "right" ? "dark-mobile-right" : "dark-mobile-left"}`}>
          {[...row.items, ...row.items].map((t) => (
            <div class="min-w-[240px] max-w-[240px] rounded-lg bg-white/[0.03] border border-white/10 p-4 flex flex-col gap-3 shrink-0">
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <Star size={11} class="text-accent fill-accent" />
                ))}
              </div>
              <p class="text-[11px] text-white/70 leading-relaxed flex-1 line-clamp-4">"{t.quote}"</p>
              <div class="flex items-center gap-2">
                <img src={t.img} alt={t.author} width="28" height="28" class="w-7 h-7 rounded-full object-cover" loading="lazy" />
                <div class="flex flex-col gap-0.5 min-w-0">
                  <span class="text-[11px] font-semibold text-white truncate">{t.author}</span>
                  <span class="text-[9px] text-accent flex items-center gap-1">
                    <BadgeCheck size={10} class="text-accent" />
                    Verified Buyer
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .dark-carousel-track {
    animation: dark-scroll 30s linear infinite;
    width: max-content;
  }
  .dark-carousel-track:hover { animation-play-state: paused; }

  @keyframes dark-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .dark-mobile-left {
    animation: dark-scroll 60s linear infinite;
    width: max-content;
  }
  .dark-mobile-right {
    animation: dark-scroll-right 60s linear infinite;
    width: max-content;
  }

  @keyframes dark-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
</style>
