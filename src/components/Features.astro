---
import { Waves, Sparkles, Sliders, Upload, Monitor, Zap } from "@lucide/astro";

const features = [
  { icon: Waves, title: "175 Ready-to-Use Presets", description: "Keys, Leads, Plucks, Bass, Synths, and Pads — 6 categories of professionally crafted sounds ready to drop into your beats." },
  { icon: Sparkles, title: "Built-in Effects Chain", description: "Shape every preset with reverb, delay, dual-band filter, vibrato, and stutter effect — all built right into the plugin." },
  { icon: Sliders, title: "Full ADSR Control", description: "Fine-tune attack, decay, sustain, and release on every sound. Plus vibrato with speed, depth, and flutter controls." },
  { icon: Upload, title: "Drag & Drop Samples", description: "Load your own WAV, MP3, AIFF, OGG, or FLAC samples via drag and drop. Each instance saves its custom sample with your project." },
  { icon: Monitor, title: "Waveform Visualization", description: "Real-time waveform display with live playhead animation so you can see exactly what you're playing." },
  { icon: Zap, title: "Lightweight & Fast", description: "16-voice polyphony with mono/legato mode, octave shift, and ping-pong delay — all running smooth with low CPU usage." },
];
---

<section id="features" class="flex flex-col items-center gap-12 md:gap-16 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4 text-center" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">FEATURES</span>
    <h2 class="font-heading text-3xl md:text-[48px] font-bold text-text-primary tracking-tight leading-tight">Designed for the Future of Sound</h2>
    <p class="text-base md:text-lg text-text-body leading-relaxed text-center max-w-[600px]">
      A sample-based synth plugin with everything you need to create — presets, effects, and your own samples, all in one place.
    </p>
  </div>

  <!-- Feature Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-[1200px]" data-animate="stagger">
    {features.map(({ icon: Icon, title, description }) => (
      <div class="rounded-xl bg-[#0D0D0F] border border-white/10 p-8 flex flex-col gap-5 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_-20%,_rgba(255,92,0,0.08)_0%,_transparent_60%)]"></div>
        <div class="relative">
          <Icon size={24} class="text-accent" />
        </div>
        <h3 class="text-lg font-semibold text-white relative">{title}</h3>
        <p class="text-[15px] text-white/50 leading-relaxed relative">{description}</p>
      </div>
    ))}
  </div>
</section>
