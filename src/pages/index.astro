---
import Layout from "../layouts/Layout.astro";
---
<Layout title="CreativAudio - Orbital Synthesizer">
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-6 p-8">
      <h1 class="font-heading text-5xl font-bold text-text">
        CreativAudio
      </h1>
      <p class="font-mono text-sm text-accent tracking-wider uppercase">
        Orbital Synthesizer
      </p>
      <p class="text-text-muted max-w-md mx-auto">
        Next-generation audio synthesis. Coming soon.
      </p>
      <div class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-heading font-bold tracking-wide">
        Explore Orbital
      </div>
      <div class="flex items-center justify-center gap-4 pt-4">
        <span class="bg-surface border border-border px-4 py-2 rounded text-sm text-text-muted">
          Surface + Border
        </span>
        <span class="bg-accent-light text-white px-4 py-2 rounded text-sm font-mono">
          Accent Light
        </span>
        <span class="bg-accent-dark text-white px-4 py-2 rounded text-sm font-mono">
          Accent Dark
        </span>
      </div>
    </div>
  </main>
</Layout>
