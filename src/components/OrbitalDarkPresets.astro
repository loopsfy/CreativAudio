---
import { Play, Pause } from "@lucide/astro";

const presets = [
  { name: "Alert", category: "Keys", file: "/audio/alert.mp3", bpm: "120", key: "C min" },
  { name: "Astral", category: "Pads", file: "/audio/astral.mp3", bpm: "90", key: "F maj" },
  { name: "Boom", category: "Bass", file: "/audio/boom.mp3", bpm: "140", key: "G min" },
  { name: "Glow", category: "Pluck", file: "/audio/glow.mp3", bpm: "110", key: "A min" },
  { name: "Jade", category: "Synth", file: "/audio/jade.mp3", bpm: "128", key: "D maj" },
  { name: "Nostalgia", category: "Keys", file: "/audio/nostalgia.mp3", bpm: "85", key: "E min" },
];
---

<section id="presets" class="relative bg-[#050507] pt-10 pb-20 md:pt-16 md:pb-[120px] px-6 md:px-16 lg:px-[120px] overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full bg-[radial-gradient(ellipse_at_center,rgba(255,92,0,0.1),transparent_70%)] blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-[1000px] mx-auto">
    <!-- Section Header -->
    <div class="flex flex-col items-center gap-4 text-center mb-12" data-animate="fade-up">
      <span class="text-xs font-semibold text-accent tracking-[2px] uppercase">Preview Presets</span>
      <h2 class="font-heading text-3xl md:text-[52px] font-bold text-white tracking-[-1.5px] leading-[1.05]">
        Hear Orbital <span class="bg-gradient-to-r from-accent to-accent-end bg-clip-text text-transparent">In Action.</span>
      </h2>
      <p class="text-base md:text-lg text-white/60 leading-relaxed max-w-[600px]">
        A taste of what's inside Orbital. Hit play on any preset — every sound sampled from real analog hardware.
      </p>
    </div>

    <!-- Preset List -->
    <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-sm overflow-hidden" data-animate="fade-in">
      <!-- Table Header -->
      <div class="hidden md:grid grid-cols-[60px_1fr_120px_100px_80px] gap-4 items-center px-6 py-4 border-b border-white/5 text-[11px] font-mono font-medium text-white/40 tracking-[1.5px] uppercase">
        <span>Play</span>
        <span>Preset</span>
        <span>Category</span>
        <span>Key</span>
        <span>BPM</span>
      </div>

      {presets.map((p, index) => (
        <div
          class:list={[
            "dark-preset group grid grid-cols-[56px_1fr_auto] md:grid-cols-[60px_1fr_120px_100px_80px] gap-4 items-center px-5 md:px-6 py-4 relative hover:bg-white/[0.03] transition-colors cursor-pointer",
            index < presets.length - 1 ? "border-b border-white/5" : ""
          ]}
          data-preset-dark
          data-file={p.file}
        >
          <!-- Play button -->
          <button class="dark-preset-play shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 border border-white/10 text-white hover:bg-accent hover:border-accent transition-colors cursor-pointer" aria-label={`Play ${p.name}`}>
            <Play size={14} class="dark-play-icon ml-0.5" />
            <Pause size={14} class="dark-pause-icon hidden" />
          </button>

          <!-- Name -->
          <div class="flex flex-col gap-0.5 min-w-0">
            <span class="text-[15px] font-semibold text-white truncate">{p.name}</span>
            <span class="md:hidden text-[11px] text-white/50">{p.category} · {p.key} · {p.bpm} BPM</span>
          </div>

          <!-- Category -->
          <span class="hidden md:inline-flex self-center w-fit text-[11px] font-mono font-medium text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1 uppercase tracking-[1px]">{p.category}</span>

          <!-- Key -->
          <span class="hidden md:inline text-[13px] font-mono text-white/60">{p.key}</span>

          <!-- BPM -->
          <span class="hidden md:inline text-[13px] font-mono text-white/60">{p.bpm}</span>

          <!-- Progress bar -->
          <div class="dark-preset-progress hidden absolute bottom-0 left-0 right-0 h-[2px] bg-white/5 overflow-hidden">
            <div class="dark-preset-progress-bar h-full bg-accent w-0"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <div class="flex items-center justify-center mt-6" data-animate="fade-up">
      <span class="text-sm text-white/40">6 of 175 presets previewed</span>
    </div>
  </div>
</section>

<style>
  [data-preset-dark].playing .dark-play-icon { display: none; }
  [data-preset-dark].playing .dark-pause-icon { display: block; }
  [data-preset-dark].playing .dark-preset-progress { display: block; }
  [data-preset-dark].playing .dark-preset-play {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
  [data-preset-dark].playing {
    background-color: rgba(255, 92, 0, 0.06);
  }
</style>

<script>
  let currentAudio: HTMLAudioElement | null = null;
  let currentPreset: HTMLElement | null = null;

  document.querySelectorAll('[data-preset-dark]').forEach((el) => {
    const preset = el as HTMLElement;
    const btn = preset.querySelector('.dark-preset-play') as HTMLButtonElement;
    const file = preset.dataset.file!;
    const progressBar = preset.querySelector('.dark-preset-progress-bar') as HTMLElement;

    const togglePlay = (e: Event) => {
      e.preventDefault();

      if (currentPreset === preset && currentAudio && !currentAudio.paused) {
        currentAudio.pause();
        preset.classList.remove('playing');
        return;
      }

      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentPreset?.classList.remove('playing');
      }

      currentAudio = new Audio(file);
      currentPreset = preset;
      preset.classList.add('playing');

      currentAudio.addEventListener('timeupdate', () => {
        if (currentAudio && currentAudio.duration) {
          progressBar.style.width = `${(currentAudio.currentTime / currentAudio.duration) * 100}%`;
        }
      });

      currentAudio.addEventListener('ended', () => {
        preset.classList.remove('playing');
        progressBar.style.width = '0%';
        currentAudio = null;
        currentPreset = null;
      });

      currentAudio.play();
    };

    btn.addEventListener('click', togglePlay);
    preset.addEventListener('click', (e) => {
      if (e.target !== btn && !btn.contains(e.target as Node)) togglePlay(e);
    });
  });
</script>
