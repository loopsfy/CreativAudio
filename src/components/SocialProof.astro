---
import { Star, BadgeCheck } from "@lucide/astro";

const stats = [
  { value: "2,100+", label: "Producers Trust Us" },
  { value: "175", label: "Presets" },
  { value: "4.9/5", label: "Rating" },
  { value: "5", label: "Built-in Effects" },
];

const testimonials = [
  {
    quote: "The 175 presets are insane. Keys, pads, leads, bass... I found sounds I actually use in every session. No filler at all.",
    author: "Alex Rivera",
    img: "https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "The built-in effects chain is a game changer. Reverb, delay, filter, vibrato and stutter all in one plugin. No need for extra sends.",
    author: "Sarah Chen",
    img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "Drag and drop my own samples and they just work. I loaded a vocal chop and turned it into a whole playable instrument in seconds.",
    author: "Marcus Johnson",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "Super lightweight on CPU. I can run multiple instances of Orbital without my laptop breaking a sweat. Perfect for live sets.",
    author: "Lena Krüger",
    img: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "Love the 4 color skins. I switched to the blue one and it fits my dark theme perfectly. Small detail that makes a big difference.",
    author: "Davi Santos",
    img: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "The waveform visualization is so helpful. Being able to see exactly what's playing while tweaking the ADSR makes sound design way faster.",
    author: "Jordan Park",
    img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "175 presets across 6 categories and every single one sits well in a mix. I've already used Orbital on three commercial releases.",
    author: "Nia Okafor",
    img: "https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "The UI is clean and intuitive. Full ADSR control, vibrato with speed and depth, everything right where you need it.",
    author: "David Lin",
    img: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "Built an entire EP with just Orbital. From pads to leads to basses, the presets cover everything and the effects add so much depth.",
    author: "Mika Tanaka",
    img: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "One-time payment, free lifetime updates, and it works on both Windows and macOS. Honestly the best value plugin I've bought this year.",
    author: "Carlos Vega",
    img: "https://images.unsplash.com/photo-1463453091185-61582044d556?w=80&h=80&fit=crop&crop=face",
  },
  {
    quote: "I loaded my own WAV samples via drag and drop and layered them with the stutter effect. The results were incredible. Worth every penny.",
    author: "Emma Whitfield",
    img: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&h=80&fit=crop&crop=face",
  },
];
---

<section id="reviews" class="flex flex-col items-center gap-12 md:gap-16 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px]">TRUSTED BY PRODUCERS</span>
    <h2 class="font-heading text-4xl md:text-[48px] font-bold text-text-primary tracking-[-1px] text-center">What Producers Say</h2>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 w-full max-w-[800px]" data-animate="stagger">
    {stats.map((stat) => (
      <div class="flex flex-col items-center gap-1.5 rounded-xl bg-gradient-to-b from-[#4d2a12] to-[#161618] border border-accent/40 py-6 px-5">
        <span class="text-2xl md:text-3xl font-heading font-bold text-white">{stat.value}</span>
        <span class="text-xs md:text-sm text-text-body tracking-wide">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Testimonials Carousel -->
  <div class="w-full max-w-full overflow-hidden relative" id="testimonial-carousel" data-animate="fade-in">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-r from-bg to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-l from-bg to-transparent z-10 pointer-events-none"></div>

    <div class="flex gap-6 carousel-track">
      {/* Duplicate testimonials for seamless loop */}
      {[...testimonials, ...testimonials].map((testimonial) => (
        <div class="min-w-[340px] max-w-[340px] rounded-xl bg-card border border-border p-8 flex flex-col gap-5 shrink-0">
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <Star size={16} class="text-accent fill-accent" />
            ))}
          </div>
          <!-- Quote -->
          <p class="text-[15px] text-text-body leading-relaxed flex-1">"{testimonial.quote}"</p>
          <!-- Author -->
          <div class="flex items-center gap-3">
            <img
              src={testimonial.img}
              alt={testimonial.author}
              width="40"
              height="40"
              class="w-10 h-10 rounded-full object-cover"
              loading="lazy"
            />
            <div class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold text-text-primary">{testimonial.author}</span>
              <span class="text-xs text-accent flex items-center gap-1">
                <BadgeCheck size={14} class="text-accent" />
                Verified Buyer
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-track {
    animation: scroll 10s linear infinite;
  }

  @media (min-width: 768px) {
    .carousel-track {
      animation: scroll 20s linear infinite;
    }
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .carousel-track.dragging {
    animation-play-state: paused;
    cursor: grabbing;
  }

  .carousel-track {
    cursor: grab;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  const track = document.querySelector('.carousel-track') as HTMLElement;
  let isDragging = false;
  let startX = 0;
  let offsetAtGrab = 0;

  function getComputedTranslateX() {
    const style = window.getComputedStyle(track);
    const matrix = new DOMMatrix(style.transform);
    return matrix.m41;
  }

  function startDrag(x: number) {
    isDragging = true;
    startX = x;
    // Capture current computed position and freeze animation
    offsetAtGrab = getComputedTranslateX();
    track.style.animation = 'none';
    track.style.transform = `translateX(${offsetAtGrab}px)`;
    track.classList.add('dragging');
  }

  function moveDrag(x: number) {
    if (!isDragging) return;
    const diff = x - startX;
    track.style.transform = `translateX(${offsetAtGrab + diff}px)`;
  }

  function endDrag() {
    if (!isDragging) return;
    isDragging = false;
    track.classList.remove('dragging');
    // Resume CSS animation from current position
    track.style.transform = '';
    track.style.animation = '';
  }

  // Mouse events
  track.addEventListener('mousedown', (e) => {
    e.preventDefault();
    startDrag(e.clientX);
  });
  window.addEventListener('mousemove', (e) => moveDrag(e.clientX));
  window.addEventListener('mouseup', endDrag);

  // Touch events
  track.addEventListener('touchstart', (e) => startDrag(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchmove', (e) => moveDrag(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchend', endDrag);
</script>
