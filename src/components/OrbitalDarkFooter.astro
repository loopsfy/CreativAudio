---
const columns = [
  { title: "Orbital", links: [
    { label: "Presets", href: "#presets" },
    { label: "Features", href: "#features" },
    { label: "Pricing", href: "#pricing" },
    { label: "FAQ", href: "#faq" },
  ]},
  { title: "Support", links: [
    { label: "Documentation", href: "#" },
    { label: "Tutorials", href: "#" },
    { label: "Contact", href: "mailto:info.creativaudio@gmail.com" },
    { label: "Refund Policy", href: "/refund-policy" },
  ]},
  { title: "Company", links: [
    { label: "About", href: "/about" },
    { label: "Home", href: "/" },
  ]},
];
---

<footer class="flex flex-col gap-12 bg-[#030304] border-t border-white/5 py-12 md:py-16 px-6 md:px-16 lg:px-[120px]">
  <div class="flex flex-col lg:flex-row lg:justify-between gap-12">
    <div class="lg:max-w-[320px] flex flex-col gap-4">
      <img src="/creativ-audio-logo.webp" alt="CreativAudio" class="h-6 w-auto invert brightness-200 self-start" />
      <p class="text-sm text-white/50 leading-relaxed">Next-generation audio synthesis tools for modern producers. Sampled from real analog hardware.</p>
    </div>

    <div class="flex flex-col sm:flex-row gap-12 sm:gap-16 lg:gap-20">
      {columns.map((col) => (
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">{col.title}</h4>
          <ul class="flex flex-col gap-2.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-white/50 hover:text-white transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="w-full h-px bg-white/10"></div>

  <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-xs text-white/40">&copy; 2026 CreativAudio. All rights reserved.</p>
    <div class="flex gap-6">
      <a href="#" class="text-xs text-white/40 hover:text-white transition-colors">Privacy Policy</a>
      <a href="#" class="text-xs text-white/40 hover:text-white transition-colors">Terms of Service</a>
      <a href="/refund-policy" class="text-xs text-white/40 hover:text-white transition-colors">Refund Policy</a>
    </div>
  </div>
</footer>
