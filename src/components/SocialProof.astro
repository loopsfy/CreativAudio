---

<section id="reviews" class="flex flex-col items-center gap-12 md:gap-16 py-16 md:py-[100px] px-6 md:px-16 lg:px-[120px]">
  <!-- Section Header -->
  <div class="flex flex-col items-center gap-4" data-animate="fade-up">
    <span class="text-xs font-semibold text-accent tracking-[2px]">TRUSTED BY PRODUCERS</span>
    <h2 class="font-heading text-4xl md:text-[48px] font-bold text-text-primary tracking-[-1px] text-center">What Producers Say</h2>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 w-full max-w-[800px]" data-animate="stagger">
    {stats.map((stat) => (
      <div class="flex flex-col items-center gap-1.5 rounded-xl bg-gradient-to-b from-[#4d2a12] to-[#161618] border border-accent/40 py-6 px-5">
        <span class="text-2xl md:text-3xl font-heading font-bold text-white">{stat.value}</span>
        <span class="text-xs md:text-sm text-text-body tracking-wide">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Testimonials Carousel -->
  <div class="w-full max-w-full overflow-hidden relative" id="testimonial-carousel" data-animate="fade-in">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-r from-bg to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-48 bg-gradient-to-l from-bg to-transparent z-10 pointer-events-none"></div>

    <div class="flex gap-6 carousel-track">
      {/* Duplicate testimonials for seamless loop */}
      {[...testimonials, ...testimonials].map((testimonial) => (
        <div class="min-w-[340px] max-w-[340px] rounded-xl bg-card border border-border p-8 flex flex-col gap-5 shrink-0">
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <Star size={16} class="text-accent fill-accent" />
            ))}
          </div>
          <!-- Quote -->
          <p class="text-[15px] text-text-body leading-relaxed flex-1">"{testimonial.quote}"</p>
          <!-- Author -->
          <div class="flex items-center gap-3">
            <img
              src={testimonial.img}
              alt={testimonial.author}
              width="40"
              height="40"
              class="w-10 h-10 rounded-full object-cover"
              loading="lazy"
            />
            <div class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold text-text-primary">{testimonial.author}</span>
              <span class="text-xs text-accent flex items-center gap-1">
                <BadgeCheck size={14} class="text-accent" />
                Verified Buyer
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-track {
    animation: scroll 10s linear infinite;
  }

  @media (min-width: 768px) {
    .carousel-track {
      animation: scroll 20s linear infinite;
    }
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .carousel-track.dragging {
    animation-play-state: paused;
    cursor: grabbing;
  }

  .carousel-track {
    cursor: grab;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  const track = document.querySelector('.carousel-track') as HTMLElement;
  let isDragging = false;
  let startX = 0;
  let offsetAtGrab = 0;

  function getComputedTranslateX() {
    const style = window.getComputedStyle(track);
    const matrix = new DOMMatrix(style.transform);
    return matrix.m41;
  }

  function startDrag(x: number) {
    isDragging = true;
    startX = x;
    // Capture current computed position and freeze animation
    offsetAtGrab = getComputedTranslateX();
    track.style.animation = 'none';
    track.style.transform = `translateX(${offsetAtGrab}px)`;
    track.classList.add('dragging');
  }

  function moveDrag(x: number) {
    if (!isDragging) return;
    const diff = x - startX;
    track.style.transform = `translateX(${offsetAtGrab + diff}px)`;
  }

  function endDrag() {
    if (!isDragging) return;
    isDragging = false;
    track.classList.remove('dragging');
    // Resume CSS animation from current position
    track.style.transform = '';
    track.style.animation = '';
  }

  // Mouse events
  track.addEventListener('mousedown', (e) => {
    e.preventDefault();
    startDrag(e.clientX);
  });
  window.addEventListener('mousemove', (e) => moveDrag(e.clientX));
  window.addEventListener('mouseup', endDrag);

  // Touch events
  track.addEventListener('touchstart', (e) => startDrag(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchmove', (e) => moveDrag(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchend', endDrag);
</script>
