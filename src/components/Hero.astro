---
import { ArrowRight } from "@lucide/astro";
---

<section class="relative flex flex-col items-center gap-6 py-16 md:py-20 px-6 md:px-16 lg:px-20 overflow-hidden">
  <!-- Background video -->
  <video autoplay loop muted playsinline preload="auto" class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none">
    <source src="/music-studio-video.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-[#F3F3F5]/60"></div>

  <!-- Social proof row -->
  <div class="flex items-center gap-3 relative z-10">
    <div class="flex -space-x-3">
      <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" alt="" class="w-9 h-9 rounded-full border-2 border-white object-cover" />
      <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" alt="" class="w-9 h-9 rounded-full border-2 border-white object-cover" />
      <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=80&h=80&fit=crop&crop=face" alt="" class="w-9 h-9 rounded-full border-2 border-white object-cover" />
    </div>
    <a href="#reviews" class="font-body text-[11px] md:text-sm text-text-body hover:text-accent transition-colors">Trusted by 2,100+ producers</a>
  </div>

  <!-- ORBITAL logo -->
  <h1 class="relative z-10">
    <img src="/orbital-logo.svg" alt="ORBITAL" width="532" height="90" class="w-[300px] md:w-[380px] lg:w-[440px] h-auto" />
  </h1>

  <!-- Hero text group -->
  <div class="flex flex-col items-center gap-4 text-center relative z-10">
    <p class="font-heading text-base md:text-[20px] font-normal text-text-body tracking-[4px] uppercase">
      Next-Generation Audio Synthesis
    </p>
    <p class="font-body text-base md:text-lg text-text-body leading-relaxed max-w-[560px]">
      A sample-based synthesizer plugin with 175 ready-to-use presets, built-in effects like reverb, delay, and filters — plus drag & drop your own samples. Available as VST3 and AU.
    </p>
  </div>

  <!-- CTA button -->
  <a
    href="#pricing"
    class="relative z-10 rounded-md bg-gradient-to-r from-accent to-accent-end px-10 py-4 text-[15px] font-semibold text-white tracking-[1px] inline-flex items-center gap-2 hover:opacity-90 transition-opacity"
  >
    GET ORBITAL
    <ArrowRight size={18} />
  </a>

  <!-- Product video -->
  <div class="w-full max-w-[900px] rounded-xl border border-border overflow-hidden relative z-10 group" id="video-container">
    <video id="product-video" loop playsinline preload="metadata" class="w-full h-auto block">
      <source src="/orbital-preview.mp4" type="video/mp4" />
    </video>

    <!-- Play/Pause button (center) -->
    <button
      id="play-pause-btn"
      class="absolute inset-0 flex items-center justify-center bg-black/30 transition-opacity duration-300"
    >
      <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white/90 backdrop-blur-sm flex items-center justify-center hover:scale-110 active:scale-95 transition-transform duration-200 shadow-lg">
        <!-- Play icon -->
        <svg id="play-icon" class="w-7 h-7 md:w-8 md:h-8 text-[#111111] ml-1" viewBox="0 0 24 24" fill="currentColor">
          <polygon points="5,3 19,12 5,21" />
        </svg>
        <!-- Pause icon (hidden) -->
        <svg id="pause-icon" class="w-7 h-7 md:w-8 md:h-8 text-[#111111] hidden" viewBox="0 0 24 24" fill="currentColor">
          <rect x="5" y="3" width="4" height="18" rx="1" />
          <rect x="15" y="3" width="4" height="18" rx="1" />
        </svg>
      </div>
    </button>

    <!-- Volume/Mute button (bottom-right) -->
    <button
      id="volume-btn"
      class="absolute bottom-3 right-3 w-10 h-10 rounded-full bg-black/50 backdrop-blur-sm flex items-center justify-center hover:bg-black/70 active:scale-95 transition-all duration-200 opacity-0 pointer-events-none"
    >
      <!-- Volume on icon -->
      <svg id="volume-on-icon" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11,5 6,9 2,9 2,15 6,15 11,19" fill="currentColor" />
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
      </svg>
      <!-- Volume mute icon (hidden) -->
      <svg id="volume-mute-icon" class="w-5 h-5 text-white hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11,5 6,9 2,9 2,15 6,15 11,19" fill="currentColor" />
        <line x1="23" y1="9" x2="17" y2="15" />
        <line x1="17" y1="9" x2="23" y2="15" />
      </svg>
    </button>
  </div>

  <script>
    const video = document.getElementById('product-video') as HTMLVideoElement;
    const playPauseBtn = document.getElementById('play-pause-btn')!;
    const playIcon = document.getElementById('play-icon')!;
    const pauseIcon = document.getElementById('pause-icon')!;
    const volumeBtn = document.getElementById('volume-btn')!;
    const volumeOnIcon = document.getElementById('volume-on-icon')!;
    const volumeMuteIcon = document.getElementById('volume-mute-icon')!;

    let isPlaying = false;

    playPauseBtn.addEventListener('click', () => {
      if (isPlaying) {
        video.pause();
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
        playPauseBtn.classList.remove('opacity-0');
        volumeBtn.classList.add('opacity-0', 'pointer-events-none');
      } else {
        video.play();
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
        // Fade out overlay after a short delay, show volume button
        setTimeout(() => {
          playPauseBtn.classList.add('opacity-0');
          volumeBtn.classList.remove('opacity-0', 'pointer-events-none');
        }, 600);
      }
      isPlaying = !isPlaying;
    });

    // Show play/pause overlay on hover when playing
    const container = document.getElementById('video-container')!;
    container.addEventListener('mouseenter', () => {
      if (isPlaying) playPauseBtn.classList.remove('opacity-0');
    });
    container.addEventListener('mouseleave', () => {
      if (isPlaying) playPauseBtn.classList.add('opacity-0');
    });

    // Volume toggle
    volumeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      video.muted = !video.muted;
      volumeOnIcon.classList.toggle('hidden');
      volumeMuteIcon.classList.toggle('hidden');
    });
  </script>

  <!-- DAW Compatibility row -->
  <div class="flex items-center gap-4 md:gap-8 py-5 flex-wrap justify-center relative z-10">
    <span class="font-body text-xs text-text-light">Compatible with</span>
    <span class="w-px h-4 bg-border-medium"></span>
    <span class="font-mono text-[13px] font-medium text-text-body">VST3</span>
    <span class="w-px h-4 bg-border-medium"></span>
    <span class="font-mono text-[13px] font-medium text-text-body">AU</span>
    <span class="w-px h-4 bg-border-medium"></span>
    <span class="font-mono text-[13px] font-medium text-text-body">Windows & macOS</span>
  </div>

</section>

